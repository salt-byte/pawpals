{
  "name": "pawpals",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "NODE_ENV=production node --import tsx/esm server.ts",
    "bootstrap:runtime": "node scripts/bootstrap-pawpals-runtime.mjs",
    "dev:isolated": "node scripts/dev-isolated.mjs",
    "desktop:dev": "node scripts/run-electron.mjs",
    "test:latest-flow": "node scripts/test-latest-job-flow.mjs",
    "test:latest-flow:hard": "node scripts/test-latest-job-flow.mjs --hard",
    "desktop:build": "vite build && electron-builder",
    "template:refresh": "node scripts/refresh-openclaw-template.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@types/multer": "^2.1.0",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "node-schedule": "^2.1.1",
    "openclaw": "^2026.3.8",
    "pdfjs-dist": "^5.5.207",
    "socket.io": "^4.8.3",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.12",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "ai.pawpals.desktop",
    "productName": "PawPals",
    "npmRebuild": true,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "resources/**/*",
      "server/**/*",
      "scripts/**/*",
      "server.ts",
      "tsconfig.json",
      "package.json"
    ],
    "asarUnpack": [
      "dist/**/*",
      "server/**/*",
      "server.ts",
      "tsconfig.json",
      "scripts/**/*",
      "resources/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.education",
      "identity": null,
      "icon": "resources/icon.icns"
    }
  }
}
